# ============================================================
#  TERATRIBE — Environment Variables
#  Copy this file as .env and fill in your values
# ============================================================

# Server
PORT=3000

# JWT Secret — change this to any long random string in production!
JWT_SECRET=teratribe_super_secret_key_change_this

# ── Razorpay ─────────────────────────────────────────────────
# Step 1: Sign up at https://razorpay.com
# Step 2: Go to Settings > API Keys > Generate Key
# Step 3: Paste your keys below

RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# NOTE:
# rzp_test_  = Test mode (fake payments, for development)
# rzp_live_  = Live mode (real payments, after KYC approval)
